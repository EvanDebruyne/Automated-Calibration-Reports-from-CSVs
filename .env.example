# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# Optional: override the default Claude model
# Options: claude-opus-4-6 (highest quality), claude-sonnet-4-6 (balanced), claude-haiku-4-5-20251001 (fastest)
CLAUDE_MODEL=claude-sonnet-4-6

# Optional: custom database path (default: data/calibration.db)
# DB_PATH=data/calibration.db
